# Copie para .env (local) ou configure no Railway como variáveis.
# NUNCA suba o .env real para o GitHub (já está no .gitignore).

# Chave secreta que protege o serviço. Invente uma string longa e aleatória.
WRAPPER_API_KEY=troque-por-uma-chave-longa-aleatoria

# Contas descartáveis do X/Twitter, em formato JSON (uma linha).
# cookies = os valores auth_token e ct0 da conta logada no navegador.
ACCOUNTS_JSON=[{"username":"minha_conta_descartavel","cookies":"auth_token=COLE_AQUI; ct0=COLE_AQUI"}]
